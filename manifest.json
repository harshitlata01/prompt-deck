{
  "manifest_version": 3,
  "name": "PromptDeck",
  "version": "1.1.0",
  "description": "Turn a slide-by-slide Markdown script into a single ChatGPT conversation: one image per slide, generated in order, then bundled into a PDF.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "tabs"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://*.oaiusercontent.com/*",
    "https://*.blob.core.windows.net/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "PromptDeck",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["lib/pdf-lib.min.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
